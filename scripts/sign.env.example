# macOS 签名与公证凭据模板
#
# 用法：
#   cp scripts/sign.env.example scripts/sign.env
#   # 填入下面的值，然后：
#   source scripts/sign.env
#   npm run tauri:build
#
# ⚠️ scripts/sign.env 已被 .gitignore 忽略，不会进仓库
#
# Tauri 2 会读取这些环境变量走 Developer ID 签名 + Apple notarytool 公证

# -------- 签名（必填）--------

# Developer ID Application 证书在钥匙串中的完整名称
# 来自：security find-identity -v -p codesigning
export APPLE_SIGNING_IDENTITY="Developer ID Application: Dizhao Fan (6633WR778C)"

# -------- 公证（必填，签名后自动提交给 Apple）--------

# Apple ID 邮箱（登录 developer.apple.com / appleid.apple.com 的邮箱）
export APPLE_ID="your.email@example.com"

# App-specific Password（在 https://appleid.apple.com 生成）
# 格式 xxxx-xxxx-xxxx-xxxx —— 不是 Apple ID 的密码
export APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Team ID（10 位字符）
export APPLE_TEAM_ID="6633WR778C"
