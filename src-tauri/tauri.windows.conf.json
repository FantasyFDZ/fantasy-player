{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "resources": {
      "vendor/mpv/*": "vendor/mpv/",
      "vendor/node.exe": "vendor/node.exe",
      "vendor/scripts/*.cjs": "vendor/scripts/",
      "vendor/node_modules": "vendor/node_modules/",
      "vendor/python": "vendor/python/",
      "vendor/sidecar/*.py": "vendor/sidecar/"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
