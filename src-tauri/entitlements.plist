<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- V8 JIT 需要可写 + 可执行内存。没有它 vendor/node 起不来，
         错误是 "Fatal process out of memory: Failed to reserve virtual memory for CodeRange" -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- 部分 V8 版本走 mmap(PROT_WRITE|PROT_EXEC) 老路径，兜底 -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- node / python 都会动态加载用 Developer ID 以外证书签的 .node / .dylib -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
