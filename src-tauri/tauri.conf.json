{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fantasy Player",
  "version": "0.1.0",
  "identifier": "com.fantasy.player",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Fantasy Player",
        "width": 1050,
        "height": 700,
        "minWidth": 1050,
        "minHeight": 700,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: data: blob:; img-src 'self' asset: data: blob: https: http:; media-src 'self' asset: data: blob: https: http:; connect-src 'self' ipc: https: http: ws: wss:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' asset: data:; object-src 'none'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
